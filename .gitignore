# ============================================
# DSA Project - Keep all source directories
# ============================================
# We want to keep:
# - core/
# - benchmarks/
# - eval/
# - tests/
# - src/
# - app/
# - agents/
# - rag/
# - infra/
# - tools/

# Just ignore cache and temp files within them

